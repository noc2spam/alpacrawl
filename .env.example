# LM Studio / Local config (default)
LM_STUDIO_URL=http://localhost:1234/v1/chat/completions
LM_STUDIO_MODEL=meta-llama/Meta-Llama-3-8B

# Or generic/OpenAI compatible API configuration (e.g. OpenAI, DeepSeek, Ollama, Groq, Together)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=your-api-key
# OPENAI_MODEL=gpt-4o

# Optional request timeout in milliseconds (default: 60000ms = 1 min)
LM_FETCH_TIMEOUT=60000